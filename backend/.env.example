# Baza konta/subskrypcje Radaru (osobny projekt Supabase od CRM)
RADAR_SUPABASE_URL=
RADAR_SUPABASE_SERVICE_KEY=

# Wspolny "market intelligence layer" (trzeci, neutralny projekt Supabase)
# Do ustalenia razem z CRM - to samo API czyta i CRM, i Radar
MARKET_INTEL_SUPABASE_URL=
MARKET_INTEL_SUPABASE_SERVICE_KEY=

# Apify - te sama infrastruktura co w CRM (mozna reuzyc token, albo osobny na start)
APIFY_TOKEN=

# Cenogram / RCN - rejestr transakcji nieruchomosci
CENOGRAM_API_KEY=

# SMSAPI.pl - bramka SMS (opcjonalna, funkcja dziala bez tego jako no-op)
SMS_API_TOKEN=

# Auth
JWT_SECRET=

PORT=4100
